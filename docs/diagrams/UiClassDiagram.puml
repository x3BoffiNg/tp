@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor UI_COLOR_T4
skinparam classBackgroundColor UI_COLOR

package UI <<Rectangle>>{
Class "<<interface>>\nUi" as Ui
Class "{abstract}\nUiPart" as UiPart
Class UiManager
Class MainWindow
Class HelpWindow
Class ResultDisplay
Class PersonListPanel
Class PersonCard
Class StatusBarFooter
Class CommandBox
Class CommandHistory
Class HelpContentProvider
}

package Model <<Rectangle>> {
Class HiddenModel #FFFFFF
}

package Logic <<Rectangle>> {
Class HiddenLogic #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Ui

UiManager .left.|> Ui
UiManager -down-> "1" MainWindow
MainWindow *-down-> "1" ResultDisplay
MainWindow *-down-> "1" PersonListPanel
MainWindow *-down-> "1" StatusBarFooter
MainWindow *-down->  "1" CommandBox
MainWindow -down-> "0..1" HelpWindow

PersonListPanel -down-> "*" PersonCard
CommandBox -down-> "1" CommandHistory
HelpWindow .right.> HelpContentProvider

MainWindow --|> UiPart

PersonCard --|> UiPart

PersonListPanel --|> UiPart
ResultDisplay --|> UiPart
StatusBarFooter --|> UiPart

CommandBox --|> UiPart
HelpWindow --|> UiPart

PersonCard .right.> Model
UiManager -right-> Logic
MainWindow -left-> Logic
CommandBox .right.> Logic
HelpContentProvider .right.> Logic


HelpWindow -[hidden]left- CommandBox
CommandBox -[hidden]left- PersonListPanel
PersonListPanel -[hidden]left- ResultDisplay
ResultDisplay -[hidden]left- StatusBarFooter

@enduml