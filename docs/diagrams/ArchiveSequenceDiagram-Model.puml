@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Model MODEL_COLOR_T1
participant ":Model" as Model MODEL_COLOR
participant "p:Person" as Person MODEL_COLOR
end box

[-> Model : archivePerson(personToArchive)
activate Model

Model -> Person : setArchived(true)
activate Person

Person --> Model
deactivate Person

[<-- Model
deactivate Model
@enduml
